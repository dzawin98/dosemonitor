        <mxCell id="Reporting" value="Reporting dan Export\nOutput CTDIvol Total DLP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#f5222d;align=center;verticalAlign=middle;" vertex="1" parent="1">
