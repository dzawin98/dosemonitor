      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="CT" value="CT Modalitas\nDICOM Sender" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f7ff;strokeColor=#1890ff;align=center;verticalAlign=middle;" vertex="1" parent="1">
