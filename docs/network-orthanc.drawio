<mxfile host="app.diagrams.net" type="device">
  <diagram id="net" name="Modality to Orthanc Network">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" background="#ffffff">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="RadiologyVLAN" value="Radiology VLAN" style="swimlane;childLayout=stackLayout;horizontal=1;rounded=1;fillColor=#f5f5f5;strokeColor=#bfbfbf;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="360" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="CT1" value="CT Modality\nAE Title: CT_SCANNER_AE\nIP: 10.10.10.21" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f7ff;strokeColor=#1890ff;align=center;verticalAlign=middle;" vertex="1" parent="RadiologyVLAN">
          <mxGeometry x="20" y="40" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="Switch" value="Core Switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#8c8c8c;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="460" y="200" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="Firewall" value="Firewall" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f0;strokeColor=#cf1322;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="640" y="200" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="DMZ" value="DMZ / Server Zone" style="swimlane;horizontal=1;rounded=1;fillColor=#f5f5f5;strokeColor=#bfbfbf;" vertex="1" parent="1">
          <mxGeometry x="820" y="140" width="420" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="Orthanc" value="Orthanc Server\nAE Title: ORTHANC_AE\nIP: 10.10.20.50\nDICOM Port: 4242\nHTTP Port: 8042" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#faad14;align=center;verticalAlign=middle;" vertex="1" parent="DMZ">
          <mxGeometry x="40" y="40" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="Notes" value="Firewall Rules\nAllow TCP 4242 from Radiology VLAN to Orthanc\nAllow TCP 8042 for admin UI (restricted)\nOptional: DICOM TLS on 4242" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#8c8c8c;align=left;verticalAlign=top;" vertex="1" parent="DMZ">
          <mxGeometry x="340" y="40" width="260" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="Echo" value="C-ECHO (verify)" edge="1" parent="1" source="CT1" target="Orthanc" style="endArrow=classic;strokeColor=#595959;dashed=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="Store" value="C-STORE (send studies)" edge="1" parent="1" source="CT1" target="Orthanc" style="endArrow=classic;strokeColor=#595959;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="Path1" value="L2/L3" edge="1" parent="1" source="RadiologyVLAN" target="Switch" style="endArrow=block;strokeColor=#8c8c8c;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="Path2" value="ACL" edge="1" parent="1" source="Switch" target="Firewall" style="endArrow=block;strokeColor=#8c8c8c;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="Path3" value="Policy" edge="1" parent="1" source="Firewall" target="DMZ" style="endArrow=block;strokeColor=#8c8c8c;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
